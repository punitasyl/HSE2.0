# ── AI backend ────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-key-here
# OLLAMA_URL=http://localhost:11434   # default
# OLLAMA_MODEL=llama3.2               # default

# ── Data source ───────────────────────────────────────────────────────────────
# DATA_SOURCE=excel      # default — reads incidents.xlsx + korgau_cards.xlsx
# DATA_SOURCE=db         # relational database via SQLAlchemy
# DATA_SOURCE=api        # REST API of the source system

# ── DB backend (DATA_SOURCE=db) ───────────────────────────────────────────────
# SOURCE_DB_URL=postgresql://user:password@host:5432/hse_db
# SOURCE_DB_URL=mssql+pyodbc://user:password@host/hse_db?driver=ODBC+Driver+17+for+SQL+Server
# SOURCE_DB_URL=oracle+cx_oracle://user:password@host:1521/?service_name=hse
# DB_INCIDENTS_TABLE=hse_incidents    # default table name
# DB_KORGAU_TABLE=korgau_cards        # default table name
# DB_INCIDENTS_QUERY=SELECT * FROM v_incidents WHERE year >= 2023   # optional raw SQL
# DB_KORGAU_QUERY=SELECT * FROM v_korgau_cards                      # optional raw SQL

# ── REST API backend (DATA_SOURCE=api) ────────────────────────────────────────
# SOURCE_API_URL=https://hse.yourcorp.kz/api/v1
# SOURCE_API_TOKEN=your-bearer-token
# API_INCIDENTS_PATH=/incidents        # default
# API_KORGAU_PATH=/korgau-cards        # default
# API_PAGE_SIZE=1000                   # default

# ── Column mapping — if source field names differ from expected ───────────────
# Comma-separated list of source_field:internal_field pairs.
# Defaults cover the most common English naming conventions.
#
# INCIDENTS_COL_MAP=incident_date:Дата возникновения происшествия,org:Организация
# KORGAU_COL_MAP=obs_date:Дата,obs_type:Тип наблюдения,org:Организация
